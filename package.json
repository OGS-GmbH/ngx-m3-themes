{
	"name": "@ogs-gmbh/ngx-m3-themes",
	"version": "1.1.0",
	"description": "Customizable Angular Material 3 (MDC) themes and helpful SCSS utilities for consistent, modern UI styling in Angular applications.",
	"keywords": [
		"light-theme",
		"angular",
		"dark-theme",
		"angular-material",
		"scss",
		"theming",
		"design-system",
		"angular-theme",
		"material3"
	],
	"homepage": "https://ogs-gmbh.github.io/ngx-m3-themes/",
	"bugs": "https://github.com/OGS-GmbH/ngx-m3-themes/issues",
	"license": "MIT",
	"author": "OGS GmbH",
	"contributors": [
		{
			"name": "Simon Kovtyk",
			"email": "simon@kovtyk.com",
			"url": "https://simonkov.dev"
		}
	],
	"exports": {
		".": {
			"sass": "./_public-api.scss"
		}
	},
	"repository": "github:OGS-GmbH/ngx-m3-themes",
	"scripts": {
		"ci:build:main:production": "ng build",
    "ci:docs:main:vitepress": "bash ./.vitepress/scripts/pre-vitepress.sh && vitepress build .vitepress",
		"ci:pr:commitlint:main:commitlint": "commitlint",
		"ci:pr:lint:main:eslint": "eslint .",
		"prepare": "husky",
    "vitepress": "bash ./.vitepress/scripts/pre-vitepress.sh && vitepress dev .vitepress",
    "vitepress-preview": "vitepress preview .vitepress"
	},
	"devDependencies": {
		"@angular/build": "^21.1.1",
		"@angular/cli": "^21.1.1",
		"@angular/compiler-cli": "^21.1.1",
		"ng-packagr": "^21.1.0",
		"@ogs-gmbh/vitepress-plugin-sidebar": "^1.0.3",
		"@ogs-gmbh/vitepress-theme": "^1.1.0",
		"@commitlint/cli": "^20.3.1",
		"@commitlint/config-conventional": "^20.3.1",
		"@commitlint/prompt-cli": "^20.3.1",
		"@ogs-gmbh/linter": "^2.0.0",
    "eslint": "^9.39.2",
		"@eslint/js": "^9.39.2",
		"@eslint/json": "^0.14.0",
		"@eslint/markdown": "^7.5.1",
		"@stylistic/eslint-plugin": "^5.7.1",
		"eslint-plugin-jsdoc": "^62.4.1",
		"eslint-plugin-unicorn": "^56.0.1",
		"husky": "^9.1.7",
    "globals": "^17",
		"lint-staged": "^16.2.7",
		"npm-package-json-lint": "^9.1.0",
		"tslib": "^2.8.1",
		"typescript": "~5.9.3",
    "angular-eslint": "^21.1.0",
    "typescript-eslint": "^8.54.0"
	},
	"peerDependencies": {
		"@angular/animations": "^21",
		"@angular/common": "^21",
		"@angular/compiler": "^21",
		"@angular/core": "^21",
		"@angular/material": "^21",
		"@ogs-gmbh/ngx-utils": "^2",
		"@ogs-gmbh/ogsid-11-theme": "^1",
		"rxjs": "~7.8.0"
	},
	"sideEffects": false,
	"publishConfig": {
		"directory": "dist/main"
	}
}
