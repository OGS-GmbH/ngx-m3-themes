{
	"name": "@ogs-gmbh/ngx-m3-themes",
	"version": "2.0.0",
	"description": "A theming system with full Material Design 3 support that enables custom color palettes, design tokens, and motion-compliant components.",
	"keywords": [
		"light-theme",
		"angular",
		"dark-theme",
		"angular-material",
		"scss",
		"theming",
		"design-system",
		"angular-theme",
		"material3"
	],
	"homepage": "https://ogs-gmbh.github.io/ngx-m3-themes/",
	"bugs": "https://github.com/OGS-GmbH/ngx-m3-themes/issues",
	"license": "MIT",
	"author": "OGS GmbH",
	"contributors": [
		{
			"name": "Simon Kovtyk",
			"email": "simon@kovtyk.com",
			"url": "https://simonkov.dev"
		}
	],
	"exports": {
		".": {
			"sass": "./_public-api.scss"
		}
	},
	"repository": "github:OGS-GmbH/ngx-m3-themes",
	"scripts": {
		"ci:build:main:production": "ng build",
		"ci:docs:extract:sassdoc": "sassdoc -p ./src | sassdoc-markdown --src-dir src --out ./dist/sassdoc",
		"ci:docs:main:vitepress": "bash ./.vitepress/scripts/pre-vitepress.sh && vitepress build .vitepress",
		"ci:pr:commitlint:main:commitlint": "commitlint",
		"ci:pr:lint:main:eslint": "eslint .",
		"commit": "commit",
		"prepare": "husky",
		"vitepress": "bash ./.vitepress/scripts/pre-vitepress.sh && vitepress dev .vitepress",
		"vitepress-preview": "vitepress preview .vitepress"
	},
	"devDependencies": {
		"@angular/build": "^21.1.2",
		"@angular/cli": "^21.1.2",
		"@angular/compiler-cli": "^21.1.2",
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"@commitlint/prompt-cli": "^20.4.1",
		"@eslint/js": "^9.39.2",
		"@eslint/json": "^0.14.0",
		"@eslint/markdown": "^7.5.1",
		"@ogs-gmbh/linter": "^2.0.1",
		"@ogs-gmbh/sassdoc-markdown": "^1.1.0",
		"@ogs-gmbh/vitepress-plugin-sidebar": "^1.0.3",
		"@ogs-gmbh/vitepress-theme": "^1.1.0",
		"@stylistic/eslint-plugin": "^5.7.1",
		"angular-eslint": "^21.2.0",
		"eslint": "^9.39.2",
		"eslint-plugin-jsdoc": "^62.5.0",
		"eslint-plugin-unicorn": "^56.0.1",
		"globals": "^17.3.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"ng-packagr": "^21.1.0",
		"npm-package-json-lint": "^9.1.0",
		"sassdoc": "^2.7.4",
		"tslib": "^2.8.1",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.54.0",
		"vitepress": "^1.6.4",
		"vitepress-plugin-group-icons": "^1.7.1"
	},
	"peerDependencies": {
		"@angular/animations": "^21",
		"@angular/common": "^21",
		"@angular/compiler": "^21",
		"@angular/core": "^21",
		"@angular/material": "^21",
		"@ogs-gmbh/ngx-utils": "^2",
		"@ogs-gmbh/ogsid-11-theme": "^1",
		"rxjs": "~7.8.0"
	},
	"sideEffects": false,
	"publishConfig": {
		"directory": "dist/main"
	}
}
